name: Update OpenAlex metrics

on:
  workflow_dispatch:
  schedule:
    - cron: "17 2 * * *"
  push:
    branches:
      - main
    paths:
      - ".github/workflows/update-openalex-stats.yml"
      - "scripts/update_openalex_stats.py"

permissions:
  contents: write

concurrency:
  group: update-openalex-metrics
  cancel-in-progress: false

jobs:
  update-openalex-metrics:
    runs-on: ubuntu-latest
    steps:
      - name: Check out repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Fetch OpenAlex author metrics
        env:
          OPENALEX_API_KEY: ${{ secrets.OPENALEX_API_KEY }}
          OPENALEX_MAILTO: ${{ secrets.OPENALEX_MAILTO }}
        run: python scripts/update_openalex_stats.py

      - name: Commit updated metrics when changed
        run: |
          if git diff --quiet -- data/openalex_metrics.json; then
            echo "OpenAlex metrics have not changed."
            exit 0
          fi
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git add data/openalex_metrics.json
          git commit -m "Update OpenAlex author metrics"
          git push
